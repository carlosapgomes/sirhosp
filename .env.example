DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=sirhosp
POSTGRES_USER=sirhosp
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Sistema legado (scraping Playwright integrado)
SOURCE_SYSTEM_URL=https://...
SOURCE_SYSTEM_USERNAME=...
SOURCE_SYSTEM_PASSWORD=...

# LLM (OpenAI ou compatível) — necessário para sumário via IA
# (legacy — prefira as variáveis SUMMARY_PHASE1_* abaixo)
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Sumário em duas fases — Fase 1 canônica (fixa, obrigatória)
# ---------------------------------------------------------------------------
SUMMARY_PHASE1_PROVIDER=openai
SUMMARY_PHASE1_MODEL=gpt-4o
SUMMARY_PHASE1_BASE_URL=https://api.openai.com/v1
SUMMARY_PHASE1_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Sumário em duas fases — Fase 2 render (até 4 opções configuráveis)
# Cada opção N={1,2,3,4} requer: LABEL, PROVIDER, MODEL, BASE_URL, API_KEY, ENABLED
# Somente opções com ENABLED=true aparecem na UI.
# ---------------------------------------------------------------------------
# Opção 1
SUMMARY_PHASE2_OPTION_1_LABEL=GPT-4o (OpenAI)
SUMMARY_PHASE2_OPTION_1_PROVIDER=openai
SUMMARY_PHASE2_OPTION_1_MODEL=gpt-4o
SUMMARY_PHASE2_OPTION_1_BASE_URL=https://api.openai.com/v1
SUMMARY_PHASE2_OPTION_1_API_KEY=sk-...
SUMMARY_PHASE2_OPTION_1_ENABLED=true
# Opção 2 (desabilitada por padrão — preencher para habilitar)
SUMMARY_PHASE2_OPTION_2_LABEL=
SUMMARY_PHASE2_OPTION_2_PROVIDER=
SUMMARY_PHASE2_OPTION_2_MODEL=
SUMMARY_PHASE2_OPTION_2_BASE_URL=
SUMMARY_PHASE2_OPTION_2_API_KEY=
SUMMARY_PHASE2_OPTION_2_ENABLED=false
# Opção 3
SUMMARY_PHASE2_OPTION_3_LABEL=
SUMMARY_PHASE2_OPTION_3_PROVIDER=
SUMMARY_PHASE2_OPTION_3_MODEL=
SUMMARY_PHASE2_OPTION_3_BASE_URL=
SUMMARY_PHASE2_OPTION_3_API_KEY=
SUMMARY_PHASE2_OPTION_3_ENABLED=false
# Opção 4
SUMMARY_PHASE2_OPTION_4_LABEL=
SUMMARY_PHASE2_OPTION_4_PROVIDER=
SUMMARY_PHASE2_OPTION_4_MODEL=
SUMMARY_PHASE2_OPTION_4_BASE_URL=
SUMMARY_PHASE2_OPTION_4_API_KEY=
SUMMARY_PHASE2_OPTION_4_ENABLED=false

# ---------------------------------------------------------------------------
# Câmbio USD/BRL para exibição de custos
# ---------------------------------------------------------------------------
# Primária (sem API key): frankfurter.dev
SUMMARY_EXCHANGE_PRIMARY_URL=https://api.frankfurter.dev/latest?from=USD&to=BRL
# Fallback (requer API key): exchangerate-api.com
SUMMARY_EXCHANGE_FALLBACK_URL=https://v6.exchangerate-api.com/v6/{api_key}/latest/USD
# Opcional — habilita fallback quando configurada
# SUMMARY_EXCHANGE_FALLBACK_API_KEY=
